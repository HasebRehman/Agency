# =========================================================================
# Curelogics Environment Variables Template
# =========================================================================
# This file is tracked by Git. Copy this to ".env.local" or ".env" and fill
# in the actual values. Do NOT commit your local config files to GitHub.

# Next.js Public Environment Variables (Prefixed with NEXT_PUBLIC_)
# NEXT_PUBLIC_API_URL=https://api.curelogics.com
# NEXT_PUBLIC_ANALYTICS_ID=

# Server-Side Secrets
# DATABASE_URL=
# API_SECRET_KEY=
